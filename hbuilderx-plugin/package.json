{
  "id": "cqsort-cc-gui",
  "name": "cqsort-cc-gui",
  "displayName": "CC GUI（Claude or Codex）",
  "description": "Claude Code / OpenAI Codex 可视化助手（HBuilderX 版）",
  "version": "0.1.6",
  "publisher": "重庆柔然科技有限公司",
  "repository": "https://github.com/wcj343169893/hbuilderx-cc-gui.git",
  "homepage": "https://github.com/wcj343169893/hbuilderx-cc-gui",
  "bugs": {
    "url": "https://github.com/wcj343169893/hbuilderx-cc-gui/issues"
  },
  "engines": {
    "HBuilderX": "^5.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension",
  "activationEvents": [
    "*",
    "onCommand:extension.ccgui.open",
    "onCommand:extension.ccgui.sendSelection",
    "onCommand:extension.ccgui.addFile",
    "onView:ccgui.chatView"
  ],
  "contributes": {
    "commands": [
      {
        "command": "extension.ccgui.open",
        "title": "打开 CC GUI 助手"
      },
      {
        "command": "extension.ccgui.sendSelection",
        "title": "发送选中代码到 CC GUI"
      },
      {
        "command": "extension.ccgui.addFile",
        "title": "添加文件到 CC GUI"
      }
    ],
    "keybindings": [
      {
        "command": "extension.ccgui.open",
        "key": "ctrl+alt+c"
      },
      {
        "command": "extension.ccgui.sendSelection",
        "key": "ctrl+alt+a",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "extension.ccgui.sendSelection",
          "group": "z_commands",
          "when": "editorTextFocus",
          "title": "发送选中代码到 CC GUI"
        }
      ],
      "explorer/context": [
        {
          "command": "extension.ccgui.addFile",
          "group": "z_commands",
          "when": "explorerResourceCount == 1 && !explorerResourceIsFolder",
          "title": "添加文件到 CC GUI"
        }
      ]
    },
    "icons": {
      "ccgui": {
        "description": "CC GUI",
        "default": {
          "fontPath": "./icons/ccgui-iconfont.ttf",
          "fontCharacter": "\\e900"
        }
      }
    },
    "viewsContainers": {
      "rightside": [
        {
          "id": "ccgui.container",
          "title": "CC GUI"
        }
      ]
    },
    "views": {
      "ccgui.container": [
        {
          "id": "ccgui.chatView",
          "name": "CC GUI",
          "title": "CC GUI（Claude or Codex）"
        }
      ]
    },
    "configuration": {
      "title": "CC GUI",
      "properties": {
        "ccgui.nodePath": {
          "type": "string",
          "default": "",
          "description": "Node.js 可执行文件路径（留空则自动探测系统 Node）"
        },
        "ccgui.claudeCliPath": {
          "type": "string",
          "default": "",
          "description": "自定义 Claude CLI 路径（留空则使用 PATH 中的 claude）"
        },
        "ccgui.permissionMode": {
          "type": "string",
          "default": "askAlways",
          "enum": [
            "askAlways",
            "acceptEdits",
            "bypassPermissions",
            "plan"
          ],
          "description": "权限模式"
        },
        "ccgui.debugLog": {
          "type": "boolean",
          "default": false,
          "description": "在「CC GUI」输出面板显示调试日志（默认关闭；无论开关都会记录到 ~/.codemoss/ccgui-debug.log）"
        }
      }
    }
  },
  "dependencies": {},
  "scripts": {
    "bundle": "node scripts/bundle.js"
  },
  "dcloudext": {
    "type": "hbuilderx",
    "sale": {
      "regular": {
        "price": "0.00"
      },
      "sourcecode": {
        "price": "0.00"
      }
    },
    "contact": {
      "qq": ""
    },
    "declaration": {
      "ads": "无",
      "data": "插件不采集任何数据",
      "permissions": "无"
    },
    "npmurl": "",
    "darkmode": "-",
    "i18n": "-",
    "widescreen": "-"
  },
  "keywords": [
    "claude",
    "codex",
    "AI",
    "agent"
]
}